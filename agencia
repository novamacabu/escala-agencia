<script>
const BIN_ID='6a5e182df5f4af5e29a79421';
const BIN_URL=`https://api.jsonbin.io/v3/b/${BIN_ID}`;
const ADMIN_PASS=atob('RmluQDQ1MA==');
const SID=Math.random().toString(36).substring(2,10);
var loggedUser=sessionStorage.getItem('escala_user')||null;
