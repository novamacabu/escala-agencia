let READ_ONLY=loggedRole!=='admin';
var _lockInterval=null,_inactivityTimer=null;
function getEmployeePass(p){if(!p.cpf)return null;var clean=p.cpf.replace(/\D/g,'');if(clean.length<4)return null;return p.name.split(' ')[0]+clean.slice(-4);}
function checkLogin(pwd){if(pwd===ADMIN_PASS)return{role:'admin',name:'Admin'};for(var i=0;i<people.length;i++){if(people[i].isAdmin&&pwd===ADMIN_PASS)return{role:'admin',name:people[i].name};var ep=getEmployeePass(people[i]);if(ep&&pwd===ep)return{role:people[i].isAdmin?'admin':'employee',name:people[i].name};}return null;}
async function acquireLock(){try{var r=await fetch(BIN_URL+'/latest',{headers:{'X-Bin-Meta':'false'}});if(!r.ok)return true;var p=await r.json();var lock=p.adminLock;var now=Date.now();if(lock&&lock.sid!==SID&&(now-lock.since)<300000){showLockBanner(lock.name||'outro admin',Math.ceil((300000-(now-lock.since))/60000));return false;}return true;}catch(e){return true;}}
function showLockBanner(who,mins){var old=document.getElementById('lock-banner');if(old&&old.parentNode)old.parentNode.removeChild(old);var b=document.createElement('div');b.id='lock-banner';b.style.cssText='position:fixed;top:0;left:0;right:0;z-index:9950;background:#7a3800;color:#fff;text-align:center;padding:14px 20px;font-size:12px;font-weight:700;';b.innerHTML='\ud83d\udd12 <b>'+who+'</b> est\u00e1 editando a escala. Tente em ~'+mins+' min. <button onclick="forceUnlock()" style="margin-left:12px;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;padding:4px 10px;border-radius:20px;cursor:pointer;font-size:11px;">For\u00e7ar acesso</button> <button onclick="this.parentElement.remove()" style="margin-left:4px;background:none;border:none;color:rgba(255,255,255,.7);cursor:pointer;font-size:14px;">\u2715</button>';document.body.prepend(b);}
async function forceUnlock(){var b=document.getElementById('lock-banner');if(b&&b.parentNode)b.parentNode.removeChild(b);await writeLock();startLockHeartbeat();READ_ONLY=false;renderAll();showToast('\u2705 Acesso for\u00e7ado');}
async function writeLock(){try{var r=await fetch(BIN_URL+'/latest',{headers:{'X-Bin-Meta':'false'}});if(!r.ok)return;var p=await r.json();p.adminLock={sid:SID,name:loggedUser||'Admin',since:Date.now()};await fetch(BIN_URL,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});}catch(e){}}
async function releaseLock(){try{var r=await fetch(BIN_URL+'/latest',{headers:{'X-Bin-Meta':'false'}});if(!r.ok)return;var p=await r.json();if(p.adminLock&&p.adminLock.sid===SID){p.adminLock=null;await fetch(BIN_URL,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});}}catch(e){}}
function startLockHeartbeat(){clearInterval(_lockInterval);_lockInterval=setInterval(function(){if(!READ_ONLY)writeLock();},120000);resetInactivity();['click','touchstart','keydown','scroll'].forEach(function(ev){document.addEventListener(ev,resetInactivity,{passive:true});});}
function resetInactivity(){clearTimeout(_inactivityTimer);_inactivityTimer=setTimeout(function(){if(!READ_ONLY){releaseLock();clearInterval(_lockInterval);READ_ONLY=true;sessionStorage.removeItem('escala_admin');showToast('\u23f1 Sess\u00e3o expirada (5 min inatividade)');logoutAdmin();}},300000);}
window.addEventListener('beforeunload',function(){if(!READ_ONLY)releaseLock();});
const SHIFT_LABELS={'1T':'1\u00ba Turno','2T':'2\u00ba Turno','TI':'Turno Integral'};
const SHIFT_ICONS={'1T':'\u23f0','2T':'\u23f0','TI':'\u23f0'};
const SHIFT_COLORS={'1T':'#b8860b','2T':'#1a4a7a','TI':'#6a1b9a'};
const SHIFT_BG={'1T':'rgba(255,236,153,0.18)','2T':'rgba(100,149,237,0.15)','TI':'rgba(186,104,200,0.12)'};
function gSL(s){return SHIFT_LABELS[s]||s;}
function gSI(s){return SHIFT_ICONS[s]||'?';}
let shiftSchedules={weekday:{'1T':{start:'07:00',breakStart:'12:00',breakEnd:'13:00',end:'14:30'},'2T':{start:'14:00',breakStart:'16:00',breakEnd:'17:00',end:'21:00'},'TI':{start:'07:00',breakStart:'12:00',breakEnd:'13:00',end:'21:00'}},weekend:{'1T':{start:'07:00',breakStart:'11:00',breakEnd:'13:30',end:'17:30'},'2T':{start:'14:00',breakStart:'16:00',breakEnd:'17:00',end:'21:00'},'TI':{start:'07:00',breakStart:'11:00',breakEnd:'13:30',end:'17:30'}}};
let isDirty=false,activeFilter='TODOS',waContacts={};
let currentYear=new Date().getFullYear(),currentMonth=new Date().getMonth();
let pontoDate=new Date();pontoDate.setHours(0,0,0,0);
const DAYS_PT=['Dom','Seg','Ter','Qua','Qui','Sex','S\u00e1b'];
const MONTHS_PT=['Janeiro','Fevereiro','Mar\u00e7o','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const MONTH_PRE=['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
const PRESET_COLORS=['#e8c97a','#72e5a8','#a99ef5','#f5a87c','#f0a0d0','#80c8f0','#f87171','#60a5fa','#34d399','#fbbf24','#e879f9','#fb923c'];
let people=[{name:'Benilce',color:'#e8c97a',phone:'',cpf:'',isAdmin:false},{name:'Carlos Vitor',color:'#72e5a8',phone:'',cpf:'',isAdmin:false},{name:'Jhenyfer',color:'#a99ef5',phone:'',cpf:'',isAdmin:false},{name:'Manoel',color:'#f5a87c',phone:'',cpf:'',isAdmin:false},{name:'M\u00f4nica',color:'#f0a0d0',phone:'',cpf:'',isAdmin:false},{name:'Renato',color:'#80c8f0',phone:'',cpf:'',isAdmin:false},{name:'Ronas',color:'#f87171',phone:'',cpf:'',isAdmin:false},{name:'Thiago',color:'#60a5fa',phone:'',cpf:'',isAdmin:false},{name:'Zilda',color:'#34d399',phone:'',cpf:'',isAdmin:false}];
function gP(n){return people.find(p=>p.name===n)||{name:n,color:'#aaa',phone:''};}
function gC(n){return gP(n).color;}
const state={},comments={};
let history=[];
const FIXED_HOLIDAYS={'01-01':'Confraterniza\u00e7\u00e3o','04-21':'Tiradentes','05-01':'Trabalho','09-07':'Independ\u00eancia','10-12':'N.Sra.Aparecida','11-02':'Finados','11-15':'Rep\u00fablica','11-20':'Consci\u00eancia Negra','12-25':'Natal'};
function computeEaster(y){var a=y%19,b=Math.floor(y/100),c=y%100,d=Math.floor(b/4),e=b%4,f=Math.floor((b+8)/25),g=Math.floor((b-f+1)/3),h=(19*a+b-d-g+15)%30,i=Math.floor(c/4),k=c%4,l=(32+2*e+2*i-h-k)%7,m=Math.floor((a+11*h+22*l)/451),mo=Math.floor((h+l-7*m+114)/31),da=((h+l-7*m+114)%31)+1;return new Date(y,mo-1,da);}
function getMobileHolidays(y){var e=computeEaster(y);function addDays(d,n){var r=new Date(d);r.setDate(r.getDate()+n);return r;}function fmt(d){return String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}var h={};var carnaval=addDays(e,-47);h[fmt(addDays(e,-48))]='Carnaval';h[fmt(carnaval)]='Carnaval';h[fmt(addDays(e,-46))]='Cinzas';h[fmt(addDays(e,-2))]='Sexta Santa';h[fmt(e)]='P\u00e1scoa';h[fmt(addDays(e,60))]='Corpus Christi';return h;}
var _holidayCache={};
function getHoliday(m,d){var y=currentYear;if(!_holidayCache[y]){_holidayCache[y]={};Object.keys(FIXED_HOLIDAYS).forEach(function(k){_holidayCache[y][k]=FIXED_HOLIDAYS[k];});var mob=getMobileHolidays(y);Object.keys(mob).forEach(function(k){_holidayCache[y][k]=mob[k];});}return _holidayCache[y][String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0')]||null;}
function makeKey(y,m,d){return y+'-'+MONTH_PRE[m]+'-'+String(d).padStart(2,'0');}
function parseKey(k){var p=k.split('-');return{year:+p[0],month:MONTH_PRE.indexOf(p[1]),day:+p[2]};}
function escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function sortS(k){if(state[k])state[k].sort((a,b)=>{var o={'1T':0,'2T':1,'TI':2};return(o[a.shift]||0)-(o[b.shift]||0);});}
function hasConflict(k){var s=state[k]||[];return s.filter(x=>x.shift==='1T').length>1||s.filter(x=>x.shift==='2T').length>1;}
function addHist(msg){history.unshift({msg,time:new Date().toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})});if(history.length>50)history.pop();}
function getDL(k){if(!k)return k;var p=parseKey(k);return p.day+' de '+MONTHS_PT[p.month]+' \u2014 '+DAYS_PT[new Date(p.year,p.month,p.day).getDay()];}
function setSS(s,t){var b=document.getElementById('sync-banner');b.className='sync-banner '+s;document.getElementById('sync-text').textContent=t;}
async function publishData(){if(READ_ONLY)return;setSS('syncing','Salvando...');try{var r=await fetch(BIN_URL,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({state,comments,people,history,waContacts,shiftSchedules,solicitacoes,savedAt:Date.now()})});if(!r.ok)throw 0;isDirty=false;try{var _sz=new Blob([JSON.stringify({state,comments,people,history,waContacts,shiftSchedules,solicitacoes})]).size;if(_sz>80000){showToast('\u26a0 Dados: '+((_sz/1024).toFixed(0))+'KB/100KB');}}catch(e){}try{localStorage.setItem('escala_nmb_cache',JSON.stringify({state,comments,people,history,waContacts,shiftSchedules,solicitacoes,savedAt:Date.now()}));}catch(e){}var n=new Date();setSS('synced','Atualizado '+n.getDate()+'/'+MONTH_PRE[n.getMonth()]+' \u00e0s '+String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0'));}catch(e){setSS('error','Falha ao salvar');showToast('\u26a0 Falha');}}
async function loadData(){setSS('syncing','Carregando...');try{var cached=localStorage.getItem('escala_nmb_cache');if(cached){var lc=JSON.parse(cached);if(lc.state)Object.keys(lc.state).forEach(function(k){if(!state[k]||!state[k].length)state[k]=lc.state[k];});if(lc.people&&lc.people.length&&people.length<=9)people.splice(0,people.length,...lc.people);if(lc.shiftSchedules)shiftSchedules=lc.shiftSchedules;if(lc.solicitacoes)solicitacoes=lc.solicitacoes;renderAll();setSS('syncing','Atualizando...');}var r=await fetch(BIN_URL+'/latest',{headers:{'X-Bin-Meta':'false'}});if(!r.ok)throw 0;var p=await r.json();if(p.savedAt&&p.savedAt>1747526400000){if(p.state)Object.keys(p.state).forEach(k=>{state[k]=p.state[k];});if(p.comments)Object.keys(p.comments).forEach(k=>{comments[k]=p.comments[k];});if(p.people&&p.people.length)people.splice(0,people.length,...p.people);if(p.history)history.splice(0,history.length,...p.history);if(p.waContacts)Object.assign(waContacts,p.waContacts);if(p.shiftSchedules)shiftSchedules=p.shiftSchedules;if(p.solicitacoes)solicitacoes=p.solicitacoes;updateSolBadge();try{localStorage.setItem('escala_nmb_cache',JSON.stringify(p));}catch(e){}var d=new Date(p.savedAt);setSS('synced','Atualizado '+d.getDate()+'/'+MONTH_PRE[d.getMonth()]+' \u00e0s '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0'));}else setSS('syncing','Primeiro acesso');renderAll();}catch(e){var hasCache=localStorage.getItem('escala_nmb_cache');setSS('error',hasCache?'Offline \u2014 usando cache local':'Sem conex\u00e3o');renderAll();}}
function markDirty(){if(READ_ONLY)return;isDirty=true;setSS('syncing','Salvando...');clearTimeout(window._ast);window._ast=setTimeout(()=>publishData(),1500);}
function toggleTheme(){document.body.classList.toggle('light');localStorage.setItem('escala_theme',document.body.classList.contains('light')?'light':'dark');}
function logoutAdmin(){releaseLock();clearInterval(_lockInterval);clearTimeout(_inactivityTimer);sessionStorage.removeItem('escala_user');sessionStorage.removeItem('escala_role');sessionStorage.removeItem('escala_admin');loggedUser=null;loggedRole=null;READ_ONLY=true;document.body.classList.add('light');var t=document.getElementById('top-bar-right');if(t)t.innerHTML='<div style="font-size:10px;color:var(--muted);padding:7px 14px;border:1px solid var(--border);border-radius:20px;">\ud83d\udc41 Escala</div><button onclick="toggleTheme()" style="font-size:10px;padding:7px 12px;border-radius:20px;cursor:pointer;background:var(--surface);border:1px solid var(--border);color:var(--muted);">\ud83d\udcf4</button><button onclick="promptLogin()" style="font-size:10px;padding:7px 12px;border-radius:20px;cursor:pointer;background:rgba(26,58,108,.1);border:1px solid rgba(26,58,108,.3);color:var(--accent);">\ud83d\udd10 Entrar</button>';renderAll();showToast('Sess\u00e3o encerrada');}
function promptLogin(){openSheet('Acesso','Entrar',function(body){var fg=document.createElement('div');fg.className='form-group';var lbl=document.createElement('div');lbl.className='form-label';lbl.textContent='Senha';var inp=document.createElement('input');inp.type='password';inp.className='text-input';inp.placeholder='\u2022\u2022\u2022\u2022\u2022\u2022';fg.appendChild(lbl);fg.appendChild(inp);body.appendChild(fg);var btn=document.createElement('button');btn.className='confirm-btn';btn.textContent='\ud83d\udd10 Entrar';btn.onclick=function(){var result=checkLogin(inp.value);if(!result){inp.value='';inp.style.borderColor='var(--pend-light)';showToast('\u26a0 Senha incorreta');setTimeout(function(){inp.style.borderColor='';},1500);return;}loggedUser=result.name;loggedRole=result.role;sessionStorage.setItem('escala_user',result.name);sessionStorage.setItem('escala_role',result.role);if(result.role==='admin'){acquireLock().then(function(ok){if(!ok){showToast('Sistema em uso por outro admin');return;}sessionStorage.setItem('escala_admin',ADMIN_PASS);READ_ONLY=false;writeLock();startLockHeartbeat();closeSheet();var t=document.getElementById('top-bar-right'),tmpl=document.getElementById('admin-buttons-template');if(t&&tmpl)t.innerHTML=tmpl.innerHTML;renderAll();showToast('\u2705 Bem-vindo, '+result.name);});}else{READ_ONLY=true;closeSheet();var t=document.getElementById('top-bar-right');if(t)t.innerHTML='<div style="font-size:10px;color:var(--accent);padding:7px 14px;border:1px solid rgba(26,58,108,.25);border-radius:20px;">\ud83e\uddd1\ud83c\udffb '+result.name+'</div><button onclick="openSolicitacao()" style="font-size:10px;padding:7px 12px;border-radius:20px;cursor:pointer;background:rgba(26,58,108,.08);border:1px solid rgba(26,58,108,.25);color:var(--accent);">\ud83d\udce7 Nova</button><button onclick="openMySolicitations()" style="font-size:10px;padding:7px 12px;border-radius:20px;cursor:pointer;background:rgba(76,175,125,.08);border:1px solid rgba(76,175,125,.25);color:#4caf7d;">\ud83d\udccb Minhas</button><button onclick="logoutAdmin()" style="font-size:10px;padding:7px 12px;border-radius:20px;cursor:pointer;background:rgba(229,114,114,.1);border:1px solid rgba(229,114,114,.3);color:#e57272;">\ud83d\udeaa</button>';renderAll();showToast('\u2705 Bem-vindo, '+result.name);}};inp.addEventListener('keydown',function(e){if(e.key==='Enter')btn.click();});body.appendChild(btn);setTimeout(function(){inp.focus();},320);});}
function setFilter(n){activeFilter=activeFilter===n?'TODOS':n;document.querySelectorAll('.filter-chip').forEach(c=>c.classList.toggle('active',c.dataset.person===activeFilter));renderAll();}
function buildFilterBar(){var fb=document.getElementById('filter-bar');fb.innerHTML='<span class="filter-bar-label">Filtrar:</span>';var all=document.createElement('div');all.className='filter-chip'+(activeFilter==='TODOS'?' active':'');all.dataset.person='TODOS';all.style.cssText='background:rgba(26,58,108,.1);border-color:rgba(26,58,108,.3);color:var(--accent);';all.textContent='Todos';all.onclick=()=>setFilter('TODOS');fb.appendChild(all);people.forEach(p=>{var c=document.createElement('div');c.className='filter-chip'+(activeFilter===p.name?' active':'');c.dataset.person=p.name;c.style.cssText='background:'+p.color+'18;border-color:'+p.color+'55;color:'+p.color+';';c.innerHTML='<span style="width:7px;height:7px;border-radius:50%;background:'+p.color+';display:inline-block;"></span>'+p.name;c.onclick=()=>setFilter(p.name);fb.appendChild(c);});}
function prevMonth(){currentMonth--;if(currentMonth<0){currentMonth=11;currentYear--;}renderAll();}
function nextMonth(){currentMonth++;if(currentMonth>11){currentMonth=0;currentYear++;}renderAll();}
function openMonthPicker(){openSheet('Nav','Selecionar M\u00eas e Ano',function(body){var fg1=document.createElement('div');fg1.className='form-group';var l1=document.createElement('div');l1.className='form-label';l1.textContent='Ano';var selY=document.createElement('select');selY.className='text-input';for(var y=2026;y<=2035;y++){var o=document.createElement('option');o.value=y;o.textContent=y;if(y===currentYear)o.selected=true;selY.appendChild(o);}fg1.appendChild(l1);fg1.appendChild(selY);body.appendChild(fg1);var fg2=document.createElement('div');fg2.className='form-group';var l2=document.createElement('div');l2.className='form-label';l2.textContent='M\u00eas';var selM=document.createElement('select');selM.className='text-input';MONTHS_PT.forEach(function(m,i){var o=document.createElement('option');o.value=i;o.textContent=m;if(i===currentMonth)o.selected=true;selM.appendChild(o);});fg2.appendChild(l2);fg2.appendChild(selM);body.appendChild(fg2);var btn=document.createElement('button');btn.className='confirm-btn';btn.textContent='Ir';btn.onclick=function(){currentYear=+selY.value;currentMonth=+selM.value;closeSheet();renderAll();};body.appendChild(btn);var cls=document.createElement('button');cls.className='cancel-btn';cls.textContent='\u2715 Fechar';cls.onclick=closeSheet;body.appendChild(cls);});}
